# Base URL da API CulturaSP-Adapter.
# Em desenvolvimento, deixe vazio: o Vite faz proxy de /v1, /health, /metrics e
# /openapi.json para http://localhost:8000 (mesma origem, sem CORS).
# Em produção (build), aponte para a URL pública da API, ex.:
# VITE_API_BASE=https://api.culturasp.example
VITE_API_BASE=
