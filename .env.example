# ─── CulturaSP-Adapter environment ────────────────────────────────────────────
# Copy to `.env` and adjust. Never commit a real `.env`.

# --- API ---
CULTURASP_API_HOST=0.0.0.0
CULTURASP_API_PORT=8000
# Comma-separated list of allowed CORS origins ("*" = all, fine for open read-only data)
CULTURASP_CORS_ORIGINS=*
# Per-IP rate limit for the public API
CULTURASP_RATE_LIMIT=60/minute

# --- Persistence ---
# Postgres: history of events, snapshots and layout hashes
CULTURASP_DATABASE_URL=postgresql+psycopg://culturasp:culturasp@postgres:5432/culturasp
# Redis: hot cache of fetched pages + rate limiting
CULTURASP_REDIS_URL=redis://redis:6379/0

# --- Scraper (ethical defaults — prioritise politeness over speed) ---
# Identifiable User-Agent (transparency > disguise)
CULTURASP_USER_AGENT=CulturaSP-Adapter/0.1 (+https://github.com/danzeroum/culturasp-adapter)
# Minimum seconds between requests to the same host
CULTURASP_SCRAPE_DELAY=3.0
# Random extra jitter (0..N seconds) added to the delay
CULTURASP_SCRAPE_JITTER=1.5
# How long a fetched page stays in Redis cache (seconds)
CULTURASP_CACHE_TTL=21600
# Whether to honour robots.txt (keep true)
CULTURASP_RESPECT_ROBOTS=true
# How often the scheduler runs a collection batch (seconds)
CULTURASP_SCRAPE_INTERVAL=1800

# --- Sources ---
# Base URL of the Sala São Paulo site (the only origin we read)
CULTURASP_SALA_SP_BASE_URL=https://salasaopaulo.art.br

# --- Observability ---
CULTURASP_LOG_LEVEL=INFO
# Optional webhook to receive layout-change alerts (leave empty to log only)
CULTURASP_ALERT_WEBHOOK_URL=
